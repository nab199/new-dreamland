  font-weight: 600;
  transition: all 0.2s ease;
}
.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(30, 132, 73, 0.3);
}

/* Secondary Button */
.btn-secondary {
  background: var(--secondary);
  color: white;
  /* ... */
}

/* Danger Button */
.btn-danger {
  background: var(--accent);
  color: white;
  /* ... */
}
```


# Dreamland College - Production Environment Configuration
# Copy this file to .env.local and fill in your actual API keys

# ==========================================
# Server Configuration
# ==========================================
PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# ==========================================
# JWT Secret - REQUIRED: Change in production!
# ==========================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==========================================
# SMS Configuration (AfroMessage)
# ==========================================
# Get your API key from: https://afromessage.com
# Sign up and get API key from dashboard

# Your AfroMessage API Key (GET FROM: https://afromessage.com/dashboard)
AFROMESSAGE_API_KEY=your-afromessage-api-key

# Sender ID (appears as sender name on phone, max 11 chars)
AFROMESSAGE_SENDER_ID=Dreamland

# ==========================================
# Email Configuration (Resend)
# ==========================================
# Get API key from: https://resend.com/api-keys

# Enable email sending
EMAIL_ENABLED=true

# Email provider (resend or smtp)
EMAIL_PROVIDER=resend

# Resend API Key (GET FROM: https://resend.com/api-keys)
RESEND_API_KEY=re_your-resend-api-key

# Email sender configuration
EMAIL_FROM_NAME=Dreamland College
EMAIL_FROM_ADDRESS=noreply@your-domain.com

# ==========================================
# Payment Configuration (Chapa)
# ==========================================
# Get keys from: https://dashboard.chapa.co/

# Chapa Secret Key (GET FROM: https://dashboard.chapa.co/developers/api-keys)
CHAPA_SECRET_KEY=CHASECK_live_your-secret-key

# Chapa Public Key (for frontend checkout)
CHAPA_PUBLIC_KEY=CHAPUB_live_your-public-key

# Webhook Secret (for verifying payment webhooks)
CHAPA_WEBHOOK_SECRET=your-webhook-secret-key

# ==========================================
# CBE Verification Service
# ==========================================
# URL to CBE verification microservice
# Deploy the CBE verifier service or set to your provider's URL

CBE_VERIFIER_URL=https://cbe-verifier.your-domain.com
CBE_VERIFIER_API_KEY=your-cbe-verifier-api-key

# ==========================================
# AI Configuration (Google Gemini)
# ==========================================
# Get API key from: https://aistudio.google.com/apikey

GEMINI_API_KEY=AIzaSyBdcld0MfZ4gVDqyMWTiC9cypP6Sozdpoo

# ==========================================
# Database Backup
# ==========================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# ==========================================
# Security
# ==========================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==========================================
# Production Checklist
# ==========================================
# 1. Set NODE_ENV=production
# 2. Change JWT_SECRET to a strong random value
# 3. Add your AfroMessage API key for SMS
# 4. Add your Resend API key for emails
# 5. Add your Chapa keys for payments
# 6. Configure CBE verifier URL (or disable if not using)
# 7. Set APP_URL to your production domain
# 8. Configure ALLOWED_ORIGINS for CORS
